# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude — used for: AI Pricing Advisor, vendor price extraction, AI bundle recommendations
ANTHROPIC_API_KEY=

# Site URL — used for OAuth redirect
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required for cron job authentication — set a long random string
CRON_SECRET=

# Stripe — billing & subscriptions
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# Developer bypass — set to 'true' to skip all plan limits locally. NEVER set in production.
BYPASS_PLAN_LIMITS=false
NEXT_PUBLIC_BYPASS_PLAN_LIMITS=false

# Phase 4 — Whop (leave empty for now)
WHOP_API_KEY=
WHOP_WEBHOOK_SECRET=
WHOP_PRODUCT_ID=
